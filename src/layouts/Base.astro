---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={Astro.url.href}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={Astro.url.href}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="お墓きれい">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "お墓きれい",
    "description": "東京・神奈川を中心とした墓石清掃代行サービス",
    "url": "https://ohaka-kirei.vercel.app",
    "areaServed": ["東京都", "神奈川県", "埼玉県", "千葉県"],
    "priceRange": "¥30,000〜",
  })} />
  <slot name="head" />
</head>
<body>
  <Header />
  <slot />
  <Footer />

  <script>
    document.querySelectorAll('a[href="#contact"]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.preventDefault();
        document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' });
      });
    });
    document.querySelectorAll('.faq-q').forEach(function(el) {
      el.addEventListener('click', function() {
        this.closest('.faq-item')?.classList.toggle('open');
      });
    });
  </script>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #1a2c45;
    --navy-light: #2a4060;
    --stone: #6b7280;
    --stone-light: #9ca3af;
    --bg: #f9f8f6;
    --white: #ffffff;
    --accent: #8b6f4e;
    --accent-light: #c4a882;
    --text: #2d2d2d;
    --text-light: #555;
    --border: #e5e1dc;
    --shadow: 0 2px 16px rgba(0,0,0,0.08);
  }

  body {
    font-family: "Hiragino Mincho ProN", "Yu Mincho", "游明朝", Georgia, serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.8;
    font-size: 16px;
  }

  /* ── ヘッダー ── */
  header {
    background: var(--navy);
    color: var(--white);
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .logo {
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    font-weight: bold;
  }
  .logo span { color: var(--accent-light); }
  header a.cta-small {
    background: var(--accent);
    color: var(--white);
    text-decoration: none;
    padding: 8px 18px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  /* ── ヒーロー ── */
  .hero {
    background: linear-gradient(160deg, var(--navy) 0%, var(--navy-light) 100%);
    color: var(--white);
    padding: 80px 24px 72px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    color: var(--accent-light);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    padding: 5px 16px;
    border-radius: 20px;
    margin-bottom: 20px;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .hero h1 {
    font-size: clamp(1.6rem, 5vw, 2.6rem);
    font-weight: bold;
    line-height: 1.5;
    margin-bottom: 20px;
    letter-spacing: 0.04em;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--accent-light);
  }
  .hero p {
    font-size: clamp(0.9rem, 2.5vw, 1.05rem);
    color: rgba(255,255,255,0.82);
    max-width: 520px;
    margin: 0 auto 36px;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .btn-primary {
    display: inline-block;
    background: var(--accent);
    color: var(--white);
    text-decoration: none;
    padding: 16px 40px;
    border-radius: 4px;
    font-size: 1rem;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    letter-spacing: 0.08em;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #7a5f3e; }
  .hero-note {
    margin-top: 16px;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }

  /* ── セクション共通 ── */
  section { padding: 72px 24px; }
  .container { max-width: 860px; margin: 0 auto; }
  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    font-family: Georgia, serif;
    margin-bottom: 8px;
  }
  .section-title {
    font-size: clamp(1.3rem, 3.5vw, 1.9rem);
    font-weight: bold;
    color: var(--navy);
    margin-bottom: 16px;
    line-height: 1.45;
  }
  .section-lead {
    color: var(--text-light);
    font-size: 0.95rem;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    max-width: 600px;
    margin-bottom: 48px;
  }
  .divider {
    width: 40px;
    height: 2px;
    background: var(--accent);
    margin: 16px 0 32px;
  }

  /* ── 課題（悩み）セクション ── */
  .problems { background: var(--white); }
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }
  .problem-card {
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    padding: 20px 22px;
    border-radius: 2px;
    background: var(--bg);
  }
  .problem-card p {
    font-size: 0.9rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    line-height: 1.7;
  }

  /* ── 提供価値 ── */
  .values { background: var(--navy); color: var(--white); }
  .values .section-title { color: var(--white); }
  .values .section-lead { color: rgba(255,255,255,0.7); }
  .values .divider { background: var(--accent-light); }
  .values .section-label { color: var(--accent-light); }
  .value-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 24px;
  }
  .value-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    padding: 28px 22px;
    text-align: center;
  }
  .value-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent-light);
    color: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: bold;
    font-family: Georgia, serif;
    margin: 0 auto 12px;
  }
  .value-card h3 {
    font-size: 1rem;
    margin-bottom: 8px;
    color: var(--accent-light);
  }
  .value-card p {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.65);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    line-height: 1.65;
  }

  /* ── サービス内容 ── */
  .services { background: var(--white); }
  .service-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }
  .service-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .service-num {
    background: var(--navy);
    color: var(--white);
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    flex-shrink: 0;
    font-family: Georgia, serif;
  }
  .service-item h3 { font-size: 0.95rem; margin-bottom: 4px; }
  .service-item p {
    font-size: 0.82rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .photo-report-box {
    background: linear-gradient(135deg, #f0ebe4, #e8e1d8);
    border: 1px solid var(--accent-light);
    border-radius: 4px;
    padding: 28px 32px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .photo-report-box h3 {
    font-size: 1rem;
    color: var(--navy);
    margin-bottom: 6px;
  }
  .photo-report-box p {
    font-size: 0.85rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }

  /* ── 対象エリア ── */
  .area { background: var(--bg); }
  .area-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .area-tag {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 6px 16px;
    font-size: 0.85rem;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    color: var(--navy);
  }
  .area-note {
    margin-top: 20px;
    font-size: 0.82rem;
    color: var(--stone-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .area-links {
    margin-top: 36px;
  }
  .area-links h3 {
    font-size: 0.95rem;
    color: var(--navy);
    margin-bottom: 16px;
  }
  .area-link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
  }
  .area-link-card {
    display: block;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px 20px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .area-link-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .area-link-name {
    display: block;
    font-size: 0.95rem;
    font-weight: bold;
    color: var(--navy);
    margin-bottom: 4px;
  }
  .area-link-loc {
    display: block;
    font-size: 0.78rem;
    color: var(--stone-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }

  /* ── 料金 ── */
  .pricing { background: var(--white); }
  .price-head {
    background: var(--navy);
    color: var(--white);
    padding: 18px 22px;
  }
  .price-head small {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.65);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    display: block;
    margin-bottom: 4px;
    letter-spacing: 0.08em;
  }
  .price-head h3 { font-size: 1rem; }
  .price-body { padding: 22px; }
  .price-amount {
    font-size: 2rem;
    font-weight: bold;
    color: var(--navy);
    margin-bottom: 4px;
  }
  .price-amount small { font-size: 0.8rem; color: var(--stone); }
  .price-desc {
    font-size: 0.82rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    margin-top: 12px;
    line-height: 1.7;
  }
  .price-includes {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .price-includes li {
    font-size: 0.8rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    list-style: none;
    padding: 3px 0;
  }
  .price-includes li::before { content: "✓　"; color: var(--accent); }
  .price-note {
    margin-top: 28px;
    font-size: 0.8rem;
    color: var(--stone-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    line-height: 1.7;
  }

  /* ── 流れ ── */
  .flow { background: var(--bg); }
  .flow-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }
  .flow-step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding-bottom: 32px;
    position: relative;
  }
  .flow-step:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 18px;
    top: 36px;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }
  .flow-num {
    background: var(--navy);
    color: var(--white);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
    font-family: Georgia, serif;
    z-index: 1;
  }
  .flow-content h3 { font-size: 1rem; margin-bottom: 4px; color: var(--navy); }
  .flow-content p {
    font-size: 0.85rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }

  /* ── FAQ ── */
  .faq { background: var(--white); }
  .faq-list { display: flex; flex-direction: column; gap: 16px; }
  .faq-item {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .faq-q {
    width: 100%;
    background: var(--bg);
    border: none;
    padding: 18px 22px;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: "Hiragino Mincho ProN", "Yu Mincho", serif;
    font-size: 0.95rem;
    color: var(--navy);
    font-weight: bold;
  }
  .faq-q span { color: var(--accent); font-size: 1.2rem; flex-shrink: 0; }
  .faq-a {
    padding: 0 22px;
    max-height: 0;
    overflow: hidden;
    font-size: 0.88rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    line-height: 1.75;
    border-top: 1px solid var(--border);
    transition: max-height 0.3s ease, padding 0.3s ease;
  }
  .faq-item.open .faq-a {
    padding: 18px 22px;
    max-height: 300px;
  }
  .faq-item.open .faq-q span:last-child {
    transform: rotate(45deg);
  }
  .faq-q span:last-child {
    transition: transform 0.2s;
  }

  /* ── CTA ── */
  .cta-section {
    background: linear-gradient(160deg, var(--navy) 0%, var(--navy-light) 100%);
    color: var(--white);
    text-align: center;
    padding: 80px 24px;
  }
  .cta-section h2 {
    font-size: clamp(1.3rem, 4vw, 2rem);
    margin-bottom: 16px;
  }
  .cta-section p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    max-width: 480px;
    margin: 0 auto 36px;
  }

  /* ── フッター ── */
  footer {
    background: #111820;
    color: rgba(255,255,255,0.4);
    text-align: center;
    padding: 32px 24px;
    font-size: 0.78rem;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }

  /* ── レスポンシブ ── */
  @media (max-width: 600px) {
    .hero { padding: 56px 20px 52px; }
    section { padding: 56px 20px; }
    .photo-report-box { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .service-photos { grid-template-columns: 1fr !important; }
    .service-photos img { height: 180px !important; }
  }
</style>
