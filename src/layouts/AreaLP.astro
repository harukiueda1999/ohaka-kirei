---
import Base from './Base.astro';
import CTA from '../components/CTA.astro';
import FAQSchema from '../components/FAQSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface AreaInfo {
  address: string;
  access: string;
  type: string;
  totalPlots: string;
  hours?: string;
  established?: string;
  url?: string;
}

interface Props {
  title: string;
  description: string;
  name: string;
  aboutText: string;
  problems: string[];
  serviceLead: string;
  faqItems: FAQItem[];
  areaInfo?: AreaInfo;
}

const { title, description, name, aboutText, problems, serviceLead, faqItems, areaInfo } = Astro.props;
---

<Base title={title} description={description}>

<FAQSchema slot="head" items={faqItems} />

<Breadcrumb items={[
  { label: "トップ", href: "/" },
  { label: "対応エリア" },
  { label: name },
]} />

<!-- ヒーロー -->
<section class="hero" style="background:linear-gradient(160deg, rgba(26,44,69,0.75) 0%, rgba(42,64,96,0.75) 100%), url('/images/cleaning-work-back.webp') center/cover no-repeat;">
  <div class="container">
    <div class="hero-badge">{name} 対応</div>
    <h1>
      {name}のお墓を、<br>
      <em>遠方からでも、きれいに。</em>
    </h1>
    <p>
      {name}にあるお墓の清掃を、ご家族に代わって丁寧に行います。
      作業前後の写真をお送りするので、現地に行けなくても安心です。
    </p>
    <div style="display:flex; justify-content:center; gap:16px; flex-wrap:wrap; margin-bottom:12px;">
      <span style="background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.2); padding:6px 16px; border-radius:20px; font-size:0.8rem; font-family:'Hiragino Kaku Gothic ProN',sans-serif; color:var(--accent-light);">作業前後の写真報告つき</span>
      <span style="background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.2); padding:6px 16px; border-radius:20px; font-size:0.8rem; font-family:'Hiragino Kaku Gothic ProN',sans-serif; color:var(--accent-light);">1回 ¥30,000（税込）</span>
    </div>
    <a href="#contact" class="btn-primary">まずは無料相談する</a>
    <p class="hero-note">お問い合わせは無料です。強引な勧誘は一切行いません。</p>
  </div>
</section>

<!-- 霊園について -->
<section class="area-intro">
  <div class="container">
    <div class="section-label">About</div>
    <h2 class="section-title">{name}のお墓清掃でお困りではありませんか</h2>
    <div class="divider"></div>
    <p class="section-lead" style="max-width:700px;" set:html={aboutText} />
    <div class="problem-grid">
      {problems.map((text) => (
        <div class="problem-card">
          <p>{text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

{areaInfo && (
<section class="area-info">
  <div class="container">
    <div class="section-label">Information</div>
    <h2 class="section-title">{name}の基本情報</h2>
    <div class="divider"></div>
    <table class="info-table">
      <tbody>
        <tr><th>所在地</th><td>{areaInfo.address}</td></tr>
        <tr><th>アクセス</th><td>{areaInfo.access}</td></tr>
        <tr><th>霊園の種類</th><td>{areaInfo.type}</td></tr>
        <tr><th>総区画数</th><td>{areaInfo.totalPlots}</td></tr>
        {areaInfo.hours && <tr><th>開園時間</th><td>{areaInfo.hours}</td></tr>}
        {areaInfo.established && <tr><th>開園</th><td>{areaInfo.established}</td></tr>}
        {areaInfo.url && <tr><th>公式サイト</th><td><a href={areaInfo.url} target="_blank" rel="noopener noreferrer">{areaInfo.url}</a></td></tr>}
      </tbody>
    </table>
  </div>
</section>
)}

<!-- 提供価値 -->
<section class="values">
  <div class="container">
    <div class="section-label">Our Value</div>
    <h2 class="section-title">私たちが提供するのは、<br>「清掃」ではなく「安心」です</h2>
    <div class="divider"></div>
    <p class="section-lead">
      墓石を磨くことそのものより、「大切にされている」という実感を届けることを大切にしています。
    </p>
    <div class="value-grid">
      <div class="value-card">
        <div class="value-icon">01</div>
        <h3>代理実行</h3>
        <p>行けない方に代わって、責任を持って{name}の現地で作業します。</p>
      </div>
      <div class="value-card">
        <div class="value-icon">02</div>
        <h3>写真報告</h3>
        <p>作業前後の写真をお送りします。目で見て確認できます。</p>
      </div>
      <div class="value-card">
        <div class="value-icon">03</div>
        <h3>明確な範囲</h3>
        <p>作業内容を事前にご説明。「思ってたのと違う」をなくします。</p>
      </div>
      <div class="value-card">
        <div class="value-icon">04</div>
        <h3>心理的な安心</h3>
        <p>「ちゃんとできていない」という後ろめたさを解消します。</p>
      </div>
    </div>
  </div>
</section>

<!-- サービス内容 -->
<section class="services">
  <div class="container">
    <div class="section-label">Services</div>
    <h2 class="section-title">サービス内容</h2>
    <div class="divider"></div>
    <p class="section-lead">{serviceLead}</p>
    <div class="service-photos" style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:40px;">
      <img src="/images/cleaning-work-front.webp" alt={`${name}での墓石清掃の作業風景`} loading="lazy" style="width:100%; height:220px; object-fit:cover; border-radius:4px;">
      <img src="/images/water-cleaning.webp" alt="墓石に水をかけて清掃" loading="lazy" style="width:100%; height:220px; object-fit:cover; border-radius:4px;">
    </div>
    <div class="service-list">
      <div class="service-item">
        <div class="service-num">1</div>
        <div>
          <h3>墓石の磨き上げ</h3>
          <p>黒ずみやコケなど、こびりついた汚れをしっかり落とします。</p>
        </div>
      </div>
      <div class="service-item">
        <div class="service-num">2</div>
        <div>
          <h3>花立・香炉の清掃</h3>
          <p>花立や香炉の汚れを落とし、清潔に整えます。</p>
        </div>
      </div>
      <div class="service-item">
        <div class="service-num">3</div>
        <div>
          <h3>雑草の除去</h3>
          <p>周辺に生えた雑草を取り除き、見た目を整えます。</p>
        </div>
      </div>
      <div class="service-item">
        <div class="service-num">4</div>
        <div>
          <h3>現地状況のご報告</h3>
          <p>気になる点があれば、写真とともにお知らせします。</p>
        </div>
      </div>
    </div>
    <div class="photo-report-box">
      <div style="width:48px; height:48px; border-radius:50%; background:var(--navy); color:var(--white); display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:bold; font-family:Georgia,serif; flex-shrink:0;">P</div>
      <div>
        <h3>作業前後の写真を必ずお送りします</h3>
        <p>「本当にやってくれたのか」という不安を解消するために、すべての作業で作業前後の写真をご報告します。遠方の方もご安心ください。</p>
      </div>
    </div>
  </div>
  <CTA size="small" />
</section>

<!-- 料金 -->
<section class="pricing">
  <div class="container">
    <div class="section-label">Pricing</div>
    <h2 class="section-title">料金</h2>
    <div class="divider"></div>
    <p class="section-lead">明朗会計。作業前にご説明するので、あとから追加費用が発生することはありません。</p>
    <div style="max-width:480px; border:1px solid var(--border); border-radius:4px; overflow:hidden;">
      <div class="price-head" style="background:var(--navy);">
        <small>STANDARD</small>
        <h3>墓石清掃</h3>
      </div>
      <div class="price-body">
        <div class="price-amount">¥30,000<small>（税込）</small></div>
        <p class="price-desc">1回あたりの料金です。お盆・お彼岸・命日など、ご希望のタイミングでご依頼いただけます。</p>
        <ul class="price-includes">
          <li>墓石の磨き上げ</li>
          <li>花立・香炉の清掃</li>
          <li>雑草除去</li>
          <li>作業前後の写真報告</li>
        </ul>
      </div>
    </div>
    <p class="price-note">
      ※ 墓石のサイズが大きい場合や、軽微な修復が必要な場合は、必要に応じてお見積もりをさせていただきます。<br>
      ※ お支払いは前払い制です（現金・銀行振込）。入金確認後に作業日を確定します。領収書を発行します。
    </p>
  </div>
</section>

<!-- ご依頼の流れ -->
<section class="flow">
  <div class="container">
    <div class="section-label">Flow</div>
    <h2 class="section-title">ご依頼の流れ</h2>
    <div class="divider"></div>
    <div class="flow-steps">
      <div class="flow-step">
        <div class="flow-num">1</div>
        <div class="flow-content">
          <h3>お問い合わせ・無料相談</h3>
          <p>フォームまたはお電話にてご連絡ください。{name}内の区画番号・ご希望日をお聞かせください。</p>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">2</div>
        <div class="flow-content">
          <h3>内容確認・お支払い</h3>
          <p>作業内容をご確認いただき、料金を前払いにてお支払いください。入金確認後に作業日を確定します。</p>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">3</div>
        <div class="flow-content">
          <h3>現地作業</h3>
          <p>ご指定の日程に{name}へ伺い、丁寧に清掃します。作業前の写真も撮影します。</p>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">4</div>
        <div class="flow-content">
          <h3>写真報告・完了</h3>
          <p>作業前後の写真をお送りし、ご確認いただいて完了となります。領収書を発行します。</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faq">
  <div class="container">
    <div class="section-label">FAQ</div>
    <h2 class="section-title">{name}についてのよくあるご質問</h2>
    <div class="divider"></div>
    <div class="faq-list">
      {faqItems.map((item) => (
        <div class="faq-item">
          <div class="faq-q">
            <span>Q</span>
            {item.question}
            <span>+</span>
          </div>
          <div class="faq-a">
            {item.answer}
          </div>
        </div>
      ))}
    </div>
    <CTA size="small" />
  </div>
</section>

<!-- 対応エリア補足 -->
<section class="other-areas">
  <div class="container">
    <h2 class="other-areas-heading">その他の対応霊園</h2>
    <p class="other-areas-lead">{name}以外にも、東京・神奈川を中心にさまざまな霊園・墓地に対応しています。</p>
    <div class="other-area-grid">
      {[
        { href: "/area/tama-reien/", label: "多磨霊園", loc: "東京都府中市" },
        { href: "/area/aoyama-reien/", label: "青山霊園", loc: "東京都港区" },
        { href: "/area/kodaira-reien/", label: "小平霊園", loc: "東京都東村山市" },
        { href: "/area/yanaka-reien/", label: "谷中霊園", loc: "東京都台東区" },
        { href: "/area/yahashira-reien/", label: "八柱霊園", loc: "千葉県松戸市" },
        { href: "/area/somei-reien/", label: "染井霊園", loc: "東京都豊島区" },
        { href: "/area/hachioji-reien/", label: "八王子霊園", loc: "東京都八王子市" },
        { href: "/area/hino-koen-bochi/", label: "日野公園墓地", loc: "横浜市港南区" },
        { href: "/area/kamakura-reien/", label: "鎌倉霊園", loc: "神奈川県鎌倉市" },
        { href: "/area/kuboyama-bochi/", label: "久保山墓地", loc: "横浜市西区" },
        { href: "/area/minamitama-reien/", label: "南多摩都市霊園", loc: "東京都八王子市" },
        { href: "/area/zoshigaya-reien/", label: "雑司ヶ谷霊園", loc: "東京都豊島区" },
      ].filter(a => !Astro.url.pathname.includes(a.href.replace(/\/$/, '').split('/').pop() || '')).slice(0, 8).map(a => (
        <a href={a.href} class="other-area-card">
          <span class="other-area-name">{a.label}</span>
          <span class="other-area-loc">{a.loc}</span>
        </a>
      ))}
    </div>
    <p class="other-areas-note">上記以外の霊園・墓地にも対応しています。お気軽にお問い合わせください。</p>
  </div>
</section>

<!-- お問い合わせ -->
<section class="cta-section" id="contact">
  <div class="container">
    <h2>{name}のお墓清掃、お気軽にご相談ください</h2>
    <p>費用や作業内容について、無料でご相談いただけます。強引なご案内は一切行いません。</p>
    <div class="contact-phone">
      <p>お電話でのご相談</p>
      <a href="tel:07084249410">070-8424-9410</a>
    </div>
    <div style="width:100%; max-width:640px; margin:0 auto; background:var(--white); border-radius:6px; overflow:hidden;">
      <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSflsamMLHBd9LgnTjPm5xKBRXpOF44xpDsxHeEXF87jdV5tRg/viewform?embedded=true" width="100%" height="2200" frameborder="0" marginheight="0" marginwidth="0" scrolling="no" style="display:block;">読み込んでいます…</iframe>
    </div>
  </div>
</section>

</Base>

<style>
  .area-intro { background: var(--white); }
  .area-info { background: var(--bg); }
  .info-table {
    max-width: 640px;
    margin: 0 auto;
    border-collapse: collapse;
    width: 100%;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    font-size: 0.88rem;
  }
  .info-table th,
  .info-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    text-align: left;
    line-height: 1.6;
  }
  .info-table th {
    width: 120px;
    color: var(--navy);
    font-weight: 600;
    white-space: nowrap;
    vertical-align: top;
  }
  .info-table td {
    color: var(--text);
  }
  .info-table a {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.82rem;
  }
  .info-table a:hover { text-decoration: underline; }
  .contact-phone {
    text-align: center;
    margin-bottom: 32px;
    padding: 24px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .contact-phone p {
    font-size: 0.85rem;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    color: rgba(255,255,255,0.8);
    margin-bottom: 8px;
  }
  .contact-phone a {
    font-size: 1.6rem;
    font-weight: bold;
    color: var(--white);
    text-decoration: none;
    font-family: Georgia, serif;
    letter-spacing: 0.05em;
  }
  .contact-phone a:hover { opacity: 0.85; }
  .contact-phone .contact-phone-note {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
    margin-top: 8px;
    margin-bottom: 0;
  }
  .other-areas { background: var(--bg); padding: 56px 24px; }
  .other-areas-heading {
    font-size: 1.2rem;
    color: var(--navy);
    text-align: center;
    margin-bottom: 8px;
  }
  .other-areas-lead {
    font-size: 0.85rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    text-align: center;
    max-width: 600px;
    margin: 0 auto 24px;
  }
  .other-area-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
    max-width: 700px;
    margin: 0 auto;
  }
  .other-area-card {
    display: block;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 16px;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .other-area-card:hover {
    border-color: var(--accent);
  }
  .other-area-name {
    display: block;
    font-size: 0.9rem;
    font-weight: bold;
    color: var(--navy);
    margin-bottom: 2px;
  }
  .other-area-loc {
    display: block;
    font-size: 0.75rem;
    color: var(--stone-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .other-areas-note {
    text-align: center;
    margin-top: 16px;
    font-size: 0.78rem;
    color: var(--stone-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
</style>
