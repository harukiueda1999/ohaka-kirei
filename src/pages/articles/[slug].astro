---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CTA from '../../components/CTA.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const [y, m, d] = article.data.date.split('-');
const displayDate = `${y}年${parseInt(m)}月${parseInt(d)}日`;
---

<Base title={`${article.data.title}｜お墓きれい`} description={article.data.description}>
  <article class="article">
    <div class="container">
      <div class="article-meta">
        <span class="article-category">{article.data.category}</span>
        <time datetime={article.data.date}>{displayDate}</time>
      </div>
      <h1>{article.data.title}</h1>
      <div class="article-body">
        <Content />
      </div>

      <!-- 中間CTA -->
      <div class="mid-cta">
        <p>お墓の汚れでお困りですか？</p>
        <a href="/#contact" class="btn-primary" style="font-size:0.9rem; padding:14px 32px;">無料相談はこちら</a>
      </div>

      <!-- 対応霊園リンク -->
      <div class="related-areas">
        <h2>対応霊園のご案内</h2>
        <p>以下の霊園をはじめ、東京・神奈川のお墓清掃に対応しています。</p>
        <div class="related-area-grid">
          <a href="/area/tama-reien/" class="related-area-card">
            <span class="related-area-name">多磨霊園</span>
            <span class="related-area-loc">東京都府中市</span>
          </a>
          <a href="/area/aoyama-reien/" class="related-area-card">
            <span class="related-area-name">青山霊園</span>
            <span class="related-area-loc">東京都港区</span>
          </a>
          <a href="/area/kodaira-reien/" class="related-area-card">
            <span class="related-area-name">小平霊園</span>
            <span class="related-area-loc">東京都東村山市</span>
          </a>
          <a href="/area/yanaka-reien/" class="related-area-card">
            <span class="related-area-name">谷中霊園</span>
            <span class="related-area-loc">東京都台東区</span>
          </a>
          <a href="/area/yahashira-reien/" class="related-area-card">
            <span class="related-area-name">八柱霊園</span>
            <span class="related-area-loc">千葉県松戸市</span>
          </a>
          <a href="/area/hino-koen-bochi/" class="related-area-card">
            <span class="related-area-name">日野公園墓地</span>
            <span class="related-area-loc">横浜市港南区</span>
          </a>
          <a href="/area/kamakura-reien/" class="related-area-card">
            <span class="related-area-name">鎌倉霊園</span>
            <span class="related-area-loc">神奈川県鎌倉市</span>
          </a>
          <a href="/area/somei-reien/" class="related-area-card">
            <span class="related-area-name">染井霊園</span>
            <span class="related-area-loc">東京都豊島区</span>
          </a>
        </div>
        <p class="related-area-note">上記以外の霊園・墓地にも対応しています。お気軽にお問い合わせください。</p>
      </div>

      <CTA />
    </div>
  </article>
</Base>

<style is:global>
  .article {
    background: var(--white);
    padding: 56px 24px 72px;
  }
  .article .container {
    max-width: 720px;
    margin: 0 auto;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .article-category {
    background: var(--navy);
    color: var(--white);
    font-size: 0.75rem;
    padding: 3px 12px;
    border-radius: 2px;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .article-meta time {
    font-size: 0.8rem;
    color: var(--stone-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .article h1 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--navy);
    line-height: 1.5;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--accent);
  }
  .article-body h2 {
    font-size: 1.25rem;
    color: var(--navy);
    margin: 48px 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .article-body h3 {
    font-size: 1.05rem;
    color: var(--navy);
    margin: 32px 0 12px;
  }
  .article-body p {
    font-size: 0.92rem;
    color: var(--text);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    line-height: 1.9;
    margin-bottom: 20px;
  }
  .article-body ul, .article-body ol {
    margin: 16px 0 24px 20px;
    font-size: 0.92rem;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    line-height: 1.8;
    color: var(--text);
  }
  .article-body li {
    margin-bottom: 6px;
  }
  .article-body strong {
    color: var(--navy);
  }
  .mid-cta {
    text-align: center;
    background: linear-gradient(135deg, #f0ebe4, #e8e1d8);
    border: 1px solid var(--accent-light);
    border-radius: 4px;
    padding: 32px 24px;
    margin: 48px 0;
  }
  .mid-cta p {
    font-size: 0.95rem;
    color: var(--navy);
    font-weight: bold;
    margin-bottom: 16px;
    font-family: "Hiragino Mincho ProN", serif;
  }
  .related-areas {
    margin: 48px 0 0;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }
  .related-areas h2 {
    font-size: 1.1rem;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .related-areas > p {
    font-size: 0.85rem;
    color: var(--text-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    margin-bottom: 20px;
  }
  .related-area-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
  }
  .related-area-card {
    display: block;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 16px;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .related-area-card:hover {
    border-color: var(--accent);
  }
  .related-area-name {
    display: block;
    font-size: 0.9rem;
    font-weight: bold;
    color: var(--navy);
    margin-bottom: 2px;
  }
  .related-area-loc {
    display: block;
    font-size: 0.75rem;
    color: var(--stone-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .related-area-note {
    margin-top: 12px;
    font-size: 0.78rem;
    color: var(--stone-light);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
</style>
